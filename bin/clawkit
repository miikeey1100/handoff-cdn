#!/usr/bin/env node
import https from 'node:https';
import { argv, stdout, stderr, exit } from 'node:process';

const RAW = 'https://raw.githubusercontent.com/miikeey1100/Claude-Design-Handoff-Vault/main/bundles';

const BUNDLES = {
  'aerodrop':     { dir: 'aerodrop-luxury-ui', file: 'AeroDrop.html',         family: 'Liquid Glass', title: 'AeroDrop — Autonomous AI Delivery',   fidelity: '98%' },
  'agentic-ops':  { dir: 'agentic-ops',        file: 'Agentic Ops.html',      family: 'Monochrome',   title: 'Agentic Ops — Swarm Console',          fidelity: '97%' },
  'biopulse':     { dir: 'biopulse-ai',        file: 'BioPulse.html',         family: 'Liquid Glass', title: 'BioPulse — AI Health Tracker',         fidelity: '96%' },
  'luxar-vault':  { dir: 'holowallet',         file: 'Luxar Vault.html',      family: 'Liquid Glass', title: 'Luxar Vault — AI Crypto Wallet',       fidelity: '98%' },
  'orchestrator': { dir: 'logicchain',         file: 'Orchestrator.html',     family: 'Monochrome',   title: 'Orchestrator — LogicChain',            fidelity: '95%' },
  'neuralstore':  { dir: 'neuralstore',        file: 'NeuralStore.html',      family: 'Monochrome',   title: 'NeuralStore — Engineered for Signal',  fidelity: '96%' },
  'frontier':     { dir: 'vibe-design',        file: 'Frontier Landing.html', family: 'Monochrome',   title: 'Frontier — The AI-native IDE',         fidelity: '94%' },
  'visionsynth':  { dir: 'visionsynth',        file: 'VisionSynth.html',      family: 'Liquid Glass', title: 'VisionSynth — AI Video Generator',     fidelity: '97%' },
};

const TOKENS = {
  'Liquid Glass': `  --glass-bg:      oklch(0.09 0.04 260)
  --glass-panel:   oklch(1 0 0 / 0.04) + backdrop-filter: blur(16px) saturate(140%)
  --glass-stroke:  oklch(1 0 0 / 0.10)
  --ink-100:       oklch(0.97 0.005 80)
  --font-display:  "SF Pro Display", "Space Grotesk", system-ui
  --font-mono:     "JetBrains Mono", monospace
  --radius:        10px / 16px / 24px / 32px`,
  'Monochrome': `  --bg:      #0a0b0c   --panel: #111315   --line: #23282d
  --ink-0:   #e9ecee  --ink-2: #9aa1a8   --ink-5: #2e3338
  --live:    #00b872  (one accent — use sparingly)
  --font-display:  "Chakra Petch", "Space Grotesk", system-ui
  --font-mono:     "JetBrains Mono", monospace
  --baseline: 4px (all spacing multiples of 4)`,
};

function fetch(url) {
  return new Promise((resolve, reject) => {
    https.get(url, res => {
      if (res.statusCode === 301 || res.statusCode === 302)
        return fetch(res.headers.location).then(resolve, reject);
      if (res.statusCode !== 200)
        return reject(new Error(`HTTP ${res.statusCode} — ${url}`));
      const chunks = [];
      res.on('data', c => chunks.push(c));
      res.on('end', () => resolve(Buffer.concat(chunks).toString('utf8')));
    }).on('error', reject);
  });
}

const [,, cmd, slug] = argv;
const slugList = Object.keys(BUNDLES).join(', ');

if (!cmd || cmd === '--help' || cmd === '-h') {
  stdout.write(`
clawkit — stream Claude Design bundles into Claude Code

  npx clawkit use <slug>       pipe a bundle to Claude Code
  npx clawkit list             show all bundles

Slugs: ${slugList}

Example:
  npx clawkit use aerodrop | claude
  claude -p "$(npx clawkit use luxar-vault)"
`);
  exit(0);
}

if (cmd === 'list') {
  stdout.write('\nAvailable Clawkit bundles:\n\n');
  for (const [s, b] of Object.entries(BUNDLES))
    stdout.write(`  ${s.padEnd(14)} ${b.fidelity} fidelity  [${b.family}]  ${b.title}\n`);
  stdout.write('\n');
  exit(0);
}

if (cmd !== 'use') {
  stderr.write(`Unknown command: ${cmd}\nTry: npx clawkit --help\n`);
  exit(1);
}

if (!slug || !BUNDLES[slug]) {
  stderr.write(`Unknown slug: "${slug}"\nAvailable: ${slugList}\n`);
  exit(1);
}

const b = BUNDLES[slug];
const htmlUrl  = `${RAW}/${b.dir}/project/${encodeURIComponent(b.file)}`;
const chatUrl  = `${RAW}/${b.dir}/chats/chat1.md`;

let html, chat;
try {
  [html, chat] = await Promise.all([fetch(htmlUrl), fetch(chatUrl).catch(() => '(no chat transcript)')]);
} catch (e) {
  stderr.write(`Fetch failed: ${e.message}\nURL: ${htmlUrl}\n`);
  exit(1);
}

stdout.write(`# Clawkit Bundle: ${b.title}
Design family: ${b.family} · Fidelity score: ${b.fidelity}

## Design Tokens (${b.family})
\`\`\`css
${TOKENS[b.family]}
\`\`\`

## Original Design Intent (from chat transcript)
${chat.split('\n').slice(0, 60).join('\n')}

## Primary Design File: ${b.file}
\`\`\`html
${html}
\`\`\`

## Instructions for Claude Code
Implement this design pixel-perfectly in whatever framework fits the target codebase (React, Vue, Swift, etc.).
- Match every color, radius, blur, and spacing value exactly as shown in the HTML above.
- Use the ${b.family} token system defined at the top as your source of truth.
- Do not add features, simplify layouts, or deviate from the visual output shown.
- If the design uses oklch() colors, preserve them — do not convert to hex.
- Full token contract: https://github.com/miikeey1100/Claude-Design-Handoff-Vault/blob/main/CLAUDE.md
`);
